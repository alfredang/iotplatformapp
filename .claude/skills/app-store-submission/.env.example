# IoTFlow — copy to a gitignored `.env` at the REPO ROOT (not here) and fill the two secrets.
# Load before running scripts:  set -a; source .env; set +a
# The `.p8` private key is NEVER committed — keep it at ASC_PRIVATE_KEY_PATH.

# --- App Store Connect API credentials (automation key) ---
ASC_KEY_ID=YQHNLVGDWK
ASC_ISSUER_ID=                            # FILL: UUID from Users and Access > Integrations > App Store Connect API
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_YQHNLVGDWK.p8

# --- App identity ---
ASC_BUNDLE_ID=com.tertiaryinfotech.iotflow
ASC_APP_ID=                               # numeric ASC App ID (write back after the app record is created)

# --- Version metadata --- (quote any value with spaces so `source .env` works)
ASC_COPYRIGHT="2026 Tertiary Infotech Pte Ltd"
ASC_PRIVACY_POLICY_URL="https://iot.tertiaryinfotech.com/privacy"
ASC_SUPPORT_URL="https://www.tertiaryinfotech.com/contact"
ASC_MARKETING_URL="https://www.tertiaryinfotech.com"

# --- App Review contact ---
ASC_CONTACT_FIRST="Alfred"
ASC_CONTACT_LAST="Ang"
ASC_CONTACT_PHONE=                        # FILL: reachable phone for App Review contact
ASC_CONTACT_EMAIL="angch@tertiaryinfotech.com"
# Reviewers can use the in-app "Explore demo" path (no account needed) — note this in review notes.
ASC_REVIEW_NOTES="No login required: tap \"Explore demo\" on the sign-in screen to explore the full app with sample data. Backend: https://iot.tertiaryinfotech.com"
